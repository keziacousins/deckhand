# Anthropic API key for LLM chat features
ANTHROPIC_API_KEY=sk-ant-...

# Server port (optional, defaults to 3008)
PORT=3008

# --- Identity & Auth (Ory) ---

# Deckhand app database
DATABASE_URL=postgresql://deckhand:deckhand@localhost:5433/deckhand

# Ory Kratos
KRATOS_PUBLIC_URL=http://localhost:4433
KRATOS_ADMIN_URL=http://localhost:4434

# Ory Hydra
HYDRA_PUBLIC_URL=http://localhost:4444
HYDRA_ADMIN_URL=http://localhost:4445

# JWT validation (derived from HYDRA_PUBLIC_URL by default)
# JWKS_URI=http://localhost:4444/.well-known/jwks.json
# OAUTH2_ISSUER=http://localhost:4444

# Public URL of the editor app (for CORS, redirect URIs)
PUBLIC_URL=http://localhost:5178

# --- Object Storage (SeaweedFS / S3-compatible) ---

S3_ENDPOINT=http://localhost:8333
S3_ACCESS_KEY=deckhand-dev-key
S3_SECRET_KEY=deckhand-dev-secret
S3_BUCKET=deckhand-assets
S3_REGION=us-east-1
