# Docker Compose environment variables.
# Copy to .env and adjust as needed.
# Defaults are set for local development — override for production.

# --- App ---

# Anthropic API key for LLM chat features
ANTHROPIC_API_KEY=sk-ant-...

# Public URL where users access the app (used for CORS, OAuth2 redirects)
PUBLIC_URL=http://localhost:3008

# --- S3-compatible Object Storage ---

S3_ACCESS_KEY=deckhand-dev-key
S3_SECRET_KEY=deckhand-dev-secret
S3_BUCKET=deckhand-assets
S3_REGION=us-east-1

# --- OAuth2 ---

OAUTH2_CLIENT_ID=deckhand-editor

# --- Ory Postgres (shared by Kratos + Hydra) ---

ORY_DB_USER=ory
ORY_DB_PASSWORD=ory

# --- Deckhand Postgres ---

DECKHAND_DB_USER=deckhand
DECKHAND_DB_PASSWORD=deckhand
DECKHAND_DB_NAME=deckhand

# --- Ory Secrets (MUST change in production) ---

KRATOS_COOKIE_SECRET=CHANGE-ME-IN-PRODUCTION-KRATOS-COOKIE-SECRET
KRATOS_CIPHER_SECRET=change-me-in-prod-32-char-key!!!
HYDRA_SYSTEM_SECRET=CHANGE-ME-IN-PRODUCTION-HYDRA-SYSTEM-SECRET!
