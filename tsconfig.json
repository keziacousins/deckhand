{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "composite": true,
  },
  "exclude": [
    "reference-code",
    "node_modules",
    "dist",
    "apps/editor",
    "apps/server",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/vitest.config.ts",
    "**/tsup.config.ts",
    "tests"
  ],
  "references": [
    { "path": "./packages/schema" },
    { "path": "./packages/sync" },
    { "path": "./packages/components" },
  ],
}
