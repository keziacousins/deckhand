{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "composite": true,
  },
  "exclude": ["reference-code", "node_modules", "dist", "apps/editor"],
  "references": [
    { "path": "./packages/schema" },
    { "path": "./packages/sync" },
    { "path": "./packages/components" },
    { "path": "./apps/server" },
  ],
}
