{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@deckhand/schema": ["../../packages/schema/src"],
      "@deckhand/sync": ["../../packages/sync/src"],
      "@deckhand/components": ["../../packages/components/src"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../../packages/schema" },
    { "path": "../../packages/sync" },
    { "path": "../../packages/components" }
  ]
}
